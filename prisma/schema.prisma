generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  lifetime
}

enum Platform {
  mobile
  web
  desktop
  both
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  plan                  Plan      @default(free)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  isAdmin               Boolean   @default(false)
  createdAt             DateTime  @default(now())
  lastLogin             DateTime?
  accounts              Account[]
  sessions              Session[]
  savedIdeas            SavedIdea[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Idea {
  id                   String    @id @default(cuid())
  slug                 String    @unique
  title                String
  genre                String
  platform             Platform
  hook                 String    // one-line pitch
  problem              String?   // what gap does this fill
  opportunity          String?   // market description
  marketSize           String?   // e.g. "$11B indie market, 12.5% CAGR"
  targetAudience       String?   // who plays this
  competitionAnalysis  String?
  similarGames         Json?     // [{name, revenue, downloads, notes}]
  whyNow               String?
  buildEstimateHours   Int?
  techStack            String?   // "Unity / Godot / HTML5 + Phaser"
  monetization         String?   // "Ads + IAP" / "Premium $2.99"
  distributionPlan     String?
  scoreMarket          Int       @default(0) // 0-25
  scoreDifficulty      Int       @default(0) // 0-25
  scoreCompetition     Int       @default(0) // 0-25
  scoreMonetization    Int       @default(0) // 0-15
  scoreTiming          Int       @default(0) // 0-10
  publishedAt          DateTime?
  featuredDate         DateTime? // idea of the day slot
  isDraft              Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  savedBy              SavedIdea[]
}

model SavedIdea {
  id        String   @id @default(cuid())
  userId    String
  ideaId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, ideaId])
}

model SubscriberEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}
